@startuml database_ER_diagram

' --- Color Customization ---
skinparam backgroundColor #fdf5f8
skinparam RoundCorner 10
skinparam Shadowing true
skinparam defaultFontColor #000000

' Entity Style (Orange/Amber for DB)
skinparam entity {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    FontColor #000000
    HeaderBackgroundColor #FFE0B2
}

' Relationship Style
skinparam arrow {
    Color #E65100
    FontColor #000000
    Thickness 1.5
}

' Notes Style (White for contrast)
skinparam note {
    BackgroundColor #FFFFFF
    BorderColor #BDBDBD
    FontColor #000000
}

title IntelliInvoice — Database ER Diagram

entity "invoice" as INVOICE {
    * id : UUID <<PK>>
    --
    store_name      : VARCHAR(255)
    invoice_date    : DATE
    total_amount    : NUMERIC(12,2)
    vat_amount      : NUMERIC(12,2)
    currency        : VARCHAR(3)
    image_url       : TEXT
    invoice_number  : INTEGER
    return_days     : INTEGER
    invoice_status  : VARCHAR(50)
    created_at      : TIMESTAMP
    updated_at      : TIMESTAMP
}

entity "invoice_item" as ITEM {
    * id : UUID <<PK>>
    --
    * invoice_id  : UUID <<FK>>
    description   : VARCHAR(255)
    quantity      : NUMERIC(12,2)
    unit_price    : NUMERIC(12,2)
    line_total    : NUMERIC(12,2)
}

INVOICE ||--o{ ITEM : "contains"

note right of INVOICE
  JPA Entity: InvoiceEntity
  @Table(name = "invoice")
  UUID auto generated
  status stored as STRING
  image stored in AWS S3
  only URL saved here
end note

note right of ITEM
  JPA Entity: InvoiceItemEntity
  @Table(name = "invoice_item")
  @ManyToOne → invoice
  ON DELETE CASCADE
  orphanRemoval = true
end note

@enduml