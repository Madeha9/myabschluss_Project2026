@startuml UC-08

skinparam actorStyle awesome
skinparam backgroundColor #fdf5f8
skinparam usecase {
    BackgroundColor #fce4ec
    BorderColor #880e4f
    FontColor #880e4f
}
skinparam actor {
    BackgroundColor #880e4f
    FontColor #880e4f
}
skinparam arrow {
    Color #880e4f
}

title UC-08 — View Spending Analytics

actor "User" as User
database "PostgreSQL" as DB

rectangle "IntelliInvoice System" {
    usecase "UC-08\nView Spending Analytics"       as UC08
    usecase "UC-14\nView Top Stores"               as UC14
    usecase "UC-15\nView Quarterly Breakdown"      as UC15
}

User --> UC08
UC08 ..> UC14 : <<include>>
UC08 ..> UC15 : <<include>>
UC08  --> DB

@enduml