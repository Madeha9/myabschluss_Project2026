@startuml UC-06

skinparam actorStyle awesome
skinparam backgroundColor #fdf5f8
skinparam usecase {
    BackgroundColor #fce4ec
    BorderColor #880e4f
    FontColor #880e4f
}
skinparam actor {
    BackgroundColor #880e4f
    FontColor #880e4f
}
skinparam arrow {
    Color #880e4f
}

title UC-06 — Delete Invoice

actor "User" as User
database "PostgreSQL" as DB

rectangle "IntelliInvoice System" {
    usecase "UC-06\nDelete Invoice"    as UC06
    usecase "Confirm Deletion"         as CONFIRM
}

User  --> UC06
UC06 ..> CONFIRM : <<include>>
UC06  --> DB

@enduml