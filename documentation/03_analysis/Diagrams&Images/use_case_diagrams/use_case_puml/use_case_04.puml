@startuml UC-04

skinparam actorStyle awesome
skinparam backgroundColor #fdf5f8
skinparam usecase {
    BackgroundColor #fce4ec
    BorderColor #880e4f
    FontColor #880e4f
}
skinparam actor {
    BackgroundColor #880e4f
    FontColor #880e4f
}
skinparam arrow {
    Color #880e4f
}

title UC-04 — Search Invoice by Store Name

actor "User" as User
database "PostgreSQL" as DB

rectangle "IntelliInvoice System" {
    usecase "UC-04\nSearch by Store Name" as UC04
    usecase "Display Results"             as RESULT
}

User   --> UC04
UC04  ..> RESULT : <<include>>
UC04   --> DB

@enduml