@startuml UC-09

skinparam actorStyle awesome
skinparam backgroundColor #fdf5f8
skinparam usecase {
    BackgroundColor #fce4ec
    BorderColor #880e4f
    FontColor #880e4f
}
skinparam actor {
    BackgroundColor #880e4f
    FontColor #880e4f
}
skinparam arrow {
    Color #880e4f
}

title UC-09 — View Original Invoice Image

actor "User" as User
cloud "AWS S3" as S3

rectangle "IntelliInvoice System" {
    usecase "UC-09\nView Original Image" as UC09
    usecase "Open Image in Browser"      as OPEN
}

User  --> UC09
UC09 ..> OPEN : <<extend>>
UC09  --> S3

@enduml